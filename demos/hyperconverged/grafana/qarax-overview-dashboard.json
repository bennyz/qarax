{
  "uid": "qarax-overview",
  "title": "Qarax Overview",
  "tags": ["qarax", "demo"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "HTTP request latency p95 by route",
      "datasource": { "type": "prometheus", "uid": "__PROM_UID__" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, route) (rate(qarax_http_request_duration_seconds_bucket{route!=\"unmatched\"}[$__rate_interval])))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "HTTP request rate by route",
      "datasource": { "type": "prometheus", "uid": "__PROM_UID__" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum by (route, method) (rate(qarax_http_request_duration_seconds_count{route!=\"unmatched\"}[$__rate_interval]))",
          "legendFormat": "{{method}} {{route}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "HTTP average latency by route",
      "datasource": { "type": "prometheus", "uid": "__PROM_UID__" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum by (route) (rate(qarax_http_request_duration_seconds_sum{route!=\"unmatched\"}[$__rate_interval])) / sum by (route) (rate(qarax_http_request_duration_seconds_count{route!=\"unmatched\"}[$__rate_interval]))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "VM start job latency p50 / p95",
      "datasource": { "type": "prometheus", "uid": "__PROM_UID__" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(qarax_vm_start_job_duration_seconds_bucket{result=\"success\"}[$__rate_interval])))",
          "legendFormat": "p50 success",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(qarax_vm_start_job_duration_seconds_bucket{result=\"success\"}[$__rate_interval])))",
          "legendFormat": "p95 success",
          "refId": "B"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "VM starts completed",
      "datasource": { "type": "prometheus", "uid": "__PROM_UID__" },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 18 },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [
        {
          "expr": "sum(increase(qarax_vm_start_jobs_total{result=\"success\"}[$__range]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "VM starts failed",
      "datasource": { "type": "prometheus", "uid": "__PROM_UID__" },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 18 },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [
        {
          "expr": "sum(increase(qarax_vm_start_jobs_total{result=\"failed\"}[$__range]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Monitor cycle duration p95 by monitor",
      "datasource": { "type": "prometheus", "uid": "__PROM_UID__" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, monitor) (rate(qarax_monitor_cycle_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "{{monitor}}",
          "refId": "A"
        }
      ]
    }
  ]
}
