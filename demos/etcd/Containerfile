# Containerfile for an etcd cluster node (qarax distributed demo)
#
# Each VM boots from this OCI image and determines its etcd identity by reading
# the IP address assigned to eth0 (statically allocated by qarax via --ip).
#
# Fixed cluster layout (hardcoded in etcd-node.sh):
#   etcd-0  10.100.0.10
#   etcd-1  10.100.0.11
#   etcd-2  10.100.0.12
#
# Build:
#   podman build -f demos/etcd/Containerfile -t localhost:5000/etcd-node:latest demos/etcd/
#   podman push localhost:5000/etcd-node:latest
#
# Then run the demo:
#   ./demos/demo-etcd-cluster.sh

FROM fedora:43

ARG ETCD_VERSION=v3.5.21

# Minimal system tools needed at runtime
RUN dnf install -y \
    iproute \
    util-linux \
    procps-ng \
    openssh-server \
    && dnf clean all

# Download etcd and etcdctl static binaries
RUN curl -fsSL \
    "https://github.com/etcd-io/etcd/releases/download/${ETCD_VERSION}/etcd-${ETCD_VERSION}-linux-amd64.tar.gz" \
    | tar -xz --strip-components=1 -C /usr/local/bin/ \
      "etcd-${ETCD_VERSION}-linux-amd64/etcd" \
      "etcd-${ETCD_VERSION}-linux-amd64/etcdctl" && \
    chmod +x /usr/local/bin/etcd /usr/local/bin/etcdctl

# Create etcd data directory
RUN mkdir -p /var/lib/etcd

# Copy startup script and systemd unit
COPY etcd-node.sh /usr/local/bin/etcd-node.sh
RUN chmod +x /usr/local/bin/etcd-node.sh

COPY etcd-node.service /etc/systemd/system/etcd-node.service

# Enable etcd service at boot
RUN mkdir -p /etc/systemd/system/multi-user.target.wants && \
    ln -sf /etc/systemd/system/etcd-node.service \
       /etc/systemd/system/multi-user.target.wants/etcd-node.service

# Configure SSH for interactive access via the demo script
RUN ssh-keygen -A && \
    sed -i 's/^#PermitRootLogin.*/PermitRootLogin yes/' /etc/ssh/sshd_config && \
    sed -i 's/^PermitRootLogin.*/PermitRootLogin yes/' /etc/ssh/sshd_config && \
    mkdir -p /etc/systemd/system/multi-user.target.wants && \
    ln -sf /usr/lib/systemd/system/sshd.service \
       /etc/systemd/system/multi-user.target.wants/sshd.service

# Set root password for console + SSH access
RUN echo "root:qarax" | chpasswd

# Generic hostname; the etcd script identifies the node by IP not hostname
RUN echo "etcd-node" > /etc/hostname
